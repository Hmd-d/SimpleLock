<?xml version="1.0" encoding="utf-8"?>
<!--
  Kiosk layout. The unlock button is anchored to the bottom of the screen
  and uses match-constraint width and a comfortable height (72dp) so it is
  always visible and always tappable — never hidden behind dynamic state.
  The 2x2 shortcut grid sits below the message so the four user-exempted
  apps remain reachable from inside lock task without needing a way out
  to MainActivity (which would reopen the boundary-edit escape).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_kiosk_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/kiosk_message"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_alrajhi"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_alrajhi"
        android:textSize="13sp"
        android:textColor="@android:color/white"
        app:strokeColor="@android:color/white"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_kiosk_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_open_dialer" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_dialer"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_dialer"
        android:textSize="13sp"
        android:textColor="@android:color/white"
        app:strokeColor="@android:color/white"
        android:layout_marginTop="24dp"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_kiosk_message"
        app:layout_constraintStart_toEndOf="@id/btn_open_alrajhi"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_contacts"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_contacts"
        android:textSize="13sp"
        android:textColor="@android:color/white"
        app:strokeColor="@android:color/white"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open_alrajhi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_open_mms" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_mms"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_mms"
        android:textSize="13sp"
        android:textColor="@android:color/white"
        app:strokeColor="@android:color/white"
        android:layout_marginTop="12dp"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open_dialer"
        app:layout_constraintStart_toEndOf="@id/btn_open_contacts"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Brightness slider available inside the kiosk too. Writes via
         Device Owner's setSystemSetting so no escape to MainActivity is
         needed to dim/brighten the screen while pinned. -->
    <TextView
        android:id="@+id/tv_brightness_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open_contacts"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <SeekBar
        android:id="@+id/seek_bar_brightness"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="255"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_brightness_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_unlock_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textSize="14sp"
        android:textColor="#DDFFFFFF"
        android:textStyle="italic"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btn_check_unlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_check_unlock"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/btn_check_unlock"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
