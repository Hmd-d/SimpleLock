<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/subtitle"
        android:textSize="14sp"
        android:alpha="0.7"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_verifying"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/checking_gps"
        android:textSize="14sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Primary action: big, prominent. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_verify_lock"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="@string/btn_verify_lock"
        android:textSize="18sp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tv_verifying"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Secondary action: outlined, smaller. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_set_boundary"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_set_boundary"
        android:textSize="14sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_verify_lock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Exempted-app shortcuts: 2x2 grid of buttons that launch each
         lock-task-whitelisted package. Visible from the home screen and
         also reachable through the same launch intent inside the kiosk. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_alrajhi"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_alrajhi"
        android:textSize="13sp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/btn_set_boundary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_open_dialer" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_dialer"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_dialer"
        android:textSize="13sp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toBottomOf="@id/btn_set_boundary"
        app:layout_constraintStart_toEndOf="@id/btn_open_alrajhi"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_contacts"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_contacts"
        android:textSize="13sp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open_alrajhi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_open_mms" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_mms"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_open_mms"
        android:textSize="13sp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open_dialer"
        app:layout_constraintStart_toEndOf="@id/btn_open_contacts"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_owner_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open_contacts"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_boundary_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_owner_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- System brightness control. Slider writes Settings.System.SCREEN_BRIGHTNESS
         via Device Owner's setSystemSetting so the change is instant and
         seamless — no Settings page redirect, no user grant flow. -->
    <TextView
        android:id="@+id/tv_brightness_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_boundary_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <SeekBar
        android:id="@+id/seek_bar_brightness"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="255"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_brightness_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
