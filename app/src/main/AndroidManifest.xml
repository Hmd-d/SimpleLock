<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Permissions intentionally trimmed for the manual architecture:
        - No ACCESS_BACKGROUND_LOCATION (location only fetched while activity is foreground)
        - No FOREGROUND_SERVICE_LOCATION (the service does no location work)
        - No RECEIVE_BOOT_COMPLETED (no boot receiver)
        - No WAKE_LOCK (no background polling)
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Lets BootReceiver re-pin the kiosk after a reboot. Not a polling
         permission — the receiver fires once on boot and does no work
         beyond launching KioskActivity. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Google Maps -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Brightness control. Granted automatically because we are Device
         Owner, which can also write system settings via
         DevicePolicyManager.setSystemSetting(). Declared explicitly so the
         fallback read path (Settings.System.getInt) also works. -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!-- Package visibility (Android 11+): we resolve launch intents for
         the user-exempted shortcut apps. -->
    <queries>
        <package android:name="com.alrajhiretailapp" />
        <package android:name="com.google.android.dialer" />
        <package android:name="com.google.android.contacts" />
        <package android:name="com.android.mms" />
    </queries>

    <application
        android:name=".SimpleLockApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleLock"
        tools:targetApi="34">

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MapActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Kiosk activity: launched explicitly from MainActivity. The HOME
             intent filter lives on KioskHomeAlias below so we can toggle it
             on only while the kiosk is actively pinned. -->
        <activity
            android:name=".KioskActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:lockTaskMode="if_whitelisted"
            android:theme="@style/Theme.SimpleLock.Kiosk" />

        <!-- HOME handler alias. Disabled by default; LockManager enables it
             before the kiosk takes over and disables it on release so the
             outside-boundary unlock hands HOME back to the system launcher
             instead of relaunching ourselves into another lock-task cycle. -->
        <activity-alias
            android:name=".KioskHomeAlias"
            android:targetActivity=".KioskActivity"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity-alias>

        <!-- Re-engages the kiosk after reboot if it was active at power-off. -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Device admin receiver — required for Device Owner provisioning. -->
        <receiver
            android:name=".receiver.AppDeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.PROFILE_PROVISIONING_COMPLETE" />
            </intent-filter>
        </receiver>

        <!--
          Minimal foreground service. Hosts the persistent kiosk notification
          while the user is in kiosk mode. NO location work, NO background
          polling — see KioskNotificationService for details.
        -->
        <service
            android:name=".service.KioskNotificationService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Persistent notification while Device Owner lock-task kiosk is active. Performs no background work." />
        </service>

    </application>
</manifest>
